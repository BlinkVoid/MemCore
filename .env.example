# --- MemCore Configuration ---

# The provider you want to use (bedrock, gemini, kimi, deepseek, ollama)
#
# RECOMMENDED: deepseek - Best value (quality/cost ratio)
#   Get API key: https://platform.deepseek.com/
#   Cost: ~60% cheaper than Kimi, similar quality
#
# ALTERNATIVES:
#   kimi - Best Chinese/English bilingual (more expensive)
#   bedrock - For AWS enterprise users
#   gemini - For Google Cloud users  
#   ollama - Free local LLM (requires GPU, lower quality)
#
LLM_PROVIDER=deepseek

# (Optional) Overrides for specific models if you don't want to use the catalogue defaults
# See: https://docs.litellm.ai/docs/providers for model naming conventions
# 
# Chat/Completion Models:
# LLM_MODEL_FAST=moonshot/moonshot-v1-8k
# LLM_MODEL_STRONG=moonshot/moonshot-v2-5-32k
#
# HYBRID MODE: Use local for fast, API for strong (cost optimization)
# LLM_MODEL_FAST=ollama/qwen3:8b        # Local (fast, cheap)
# LLM_MODEL_STRONG=moonshot/moonshot-v2-5-32k  # API (quality)
# Then set LLM_PROVIDER to match your STRONG model provider
# ==============================================================================
# EMBEDDING MODEL - READ CAREFULLY BEFORE CHANGING
# ==============================================================================
# ⚠️  WARNING: Changing the embedding model after data is stored requires 
#     RE-INDEXING your entire vector database! Choose wisely upfront.
#
# CHOOSE BASED ON LANGUAGE NEEDS:
#
# 1. MULTILINGUAL DEFAULT (Chinese, English, 100+ languages)
#    DEFAULT: local/intfloat/multilingual-e5-large (1024-dim, 2.24GB)
#    - Supports 100+ languages including Chinese, Japanese, Korean
#    - State-of-the-art multilingual retrieval (MTEB: 62.3)
#    - Use with Kimi for best Chinese/English bilingual support
#    - Requires ~4GB RAM
#
# 2. ENGLISH-ONLY (Smaller & Faster)
#    Use this if you ONLY need English and want smaller footprint:
#    local/BAAI/bge-base-en-v1.5 (768-dim, 210MB)
#    - Faster inference, smaller memory footprint
#    - MTEB Score: 63.5 (excellent for English)
#
# 3. OTHER LOCAL OPTIONS:
#    - local/BAAI/bge-small-en-v1.5    : 384-dim, 67MB (lightweight, English)
#    - local/BAAI/bge-large-en-v1.5    : 1024-dim, 1.2GB (English, highest quality)
#    - local/snowflake-arctic-embed-m  : 768-dim, 430MB (good for retrieval)
#    - local/BAAI/bge-small-zh-v1.5    : 512-dim, 90MB (Chinese-optimized)
#
# 4. CLOUD OPTIONS (vendor-specific - NOT RECOMMENDED):
#    - moonshot/moonshot-embed-v1      : 1536-dim (Kimi)
#    - bedrock/amazon.titan-embed-text-v2:0 : 1024-dim (AWS)
#    - gemini/text-embedding-004       : 768-dim (Google)
#
# DEFAULT: Multilingual (supports Chinese)
EMBEDDING_MODEL=local/intfloat/multilingual-e5-large
#
# FOR ENGLISH-ONLY (uncomment if you want smaller footprint):
# EMBEDDING_MODEL=local/BAAI/bge-base-en-v1.5

# --- Provider Specific Keys ---

# 1. DeepSeek (RECOMMENDED - Best value)
#    Get your API key: https://platform.deepseek.com/
#    Pricing: ~60% cheaper than Kimi, similar quality
DEEPSEEK_API_KEY=your_deepseek_key

# 2. Kimi (Moonshot) - Best Chinese/English bilingual support
#    Get your API key: https://platform.moonshot.cn/
#    Pricing: Higher cost, excellent Chinese support
# MOONSHOT_API_KEY=your_kimi_key

# 3. Gemini - For Google Cloud users
#    Get your API key: https://ai.google.dev/
# GEMINI_API_KEY=your_gemini_key

# 4. Bedrock - For AWS enterprise users
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION_NAME=us-east-1

# 5. Ollama (Local LLM) - No API key needed
DEEPSEEK_API_KEY=your_deepseek_key

# 5. If using Ollama (Local LLM - FREE, no API key needed!)
# First install Ollama: https://ollama.com
# Then pull models: ollama pull qwen2.5:7b qwen2.5:14b
# OLLAMA_HOST=http://localhost:11434  # Default, usually don't need to change

# --- System Paths ---
# Path to your Obsidian vault or markdown folder for syncing
OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault

# --- Agent Platform (Optional) ---
# Only needed if you are using the Strands cloud platform features
STRANDS_API_KEY=your_strands_platform_key
