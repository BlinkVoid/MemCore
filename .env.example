# --- MemCore Configuration ---

# The provider you want to use (bedrock, gemini, kimi, deepseek)
LLM_PROVIDER=bedrock

# (Optional) Overrides for specific models if you don't want to use the catalogue defaults
# LLM_MODEL_FAST=...
# LLM_MODEL_STRONG=...

# --- Provider Specific Keys ---

# 1. If using Bedrock (Requires AWS credentials)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION_NAME=us-east-1

# 2. If using Gemini
GEMINI_API_KEY=your_gemini_key

# 3. If using Kimi (Moonshot)
MOONSHOT_API_KEY=your_kimi_key

# 4. If using DeepSeek
DEEPSEEK_API_KEY=your_deepseek_key

# --- System Paths ---
# Path to your Obsidian vault or markdown folder for syncing
OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault

# --- Agent Platform (Optional) ---
# Only needed if you are using the Strands cloud platform features
STRANDS_API_KEY=your_strands_platform_key
